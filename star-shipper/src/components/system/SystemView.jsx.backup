// Ship physics
const SHIP_ACCELERATION = 300;
const SHIP_BRAKE_POWER = 200;
const SHIP_MAX_SPEED = 500;
const SHIP_DRAG = 0.995; // Very low drag for space feel
const SHIP_ROTATION_SPEED = 180; // Degrees per second

// ============================================
// SEEDED RANDOM (for procedural generation)
// ============================================

class SeededRandom {
  constructor(seed) {
    this.seed = seed;
  }
  
  next() {
    this.seed = (this.seed * 1103515245 + 12345) & 0x7fffffff;
    return this.seed / 0x7fffffff;
  }
  
  range(min, max) {
    return min + this.next() * (max - min);
  }
  
  int(min, max) {
    return Math.floor(this.range(min, max + 1));
  }
  
  pick(array) {
    return array[Math.floor(this.next() * array.length)];
  }
  
  chance(probability) {
    return this.next() < probability;
  }
}

